<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/purple_lighter"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarAddEditBook"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/purple_lighter"
        app:navigationIcon="@drawable/ic_arrow_back_24"
        app:title="Add Book"
        app:titleTextColor="@color/text_main" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Book Title"
                android:textColor="@color/text_muted"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/edtBookTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:hint="Enter book title"
                android:padding="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Author"
                android:textColor="@color/text_muted"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/edtBookAuthor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:hint="Enter author name"
                android:padding="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Introduction"
                android:textColor="@color/text_muted"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/edtBookIntro"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_marginTop="6dp"
                android:gravity="top|start"
                android:hint="Enter short introduction"
                android:inputType="textMultiLine"
                android:padding="12dp" />

            <CheckBox
                android:id="@+id/cbBookAvailable"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:checked="true"
                android:text="Available for borrowing"
                android:textColor="@color/text_main" />

            <Button
                android:id="@+id/btnSaveBook"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:backgroundTint="@color/purple_primary"
                android:text="Save"
                android:textAllCaps="false"
                android:textColor="@android:color/white" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>